// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  password         String
  role             String                   @default("SEEKER") // SEEKER, RECRUITER
  profile          Profile?
  recruiter        Recruiter?
  applications     Application[]
  matches          Match[]
  savedJobs        SavedJob[]
  memories         Memory[]
  jobFeedbacks     JobFeedback[]
  jobPreferences   JobPreference?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  name         String?
  headline     String?
  bio          String?
  skills       String? // JSON string
  education    String? // JSON string
  experience   String? // JSON string
  projects     String? // JSON string
  achievements String? // JSON string
  resume       Resume?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Resume {
  id         String   @id @default(cuid())
  profileId  String   @unique
  profile    Profile  @relation(fields: [profileId], references: [id])
  content    String?
  fileUrl    String?
  parsedData String? // JSON string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Job {
  id              String        @id @default(cuid())
  title           String
  company         String
  description     String
  requirements    String?
  location        String?
  salary          String?
  type            String? // FULL_TIME, PART_TIME, INTERNSHIP
  category        String?
  experienceLevel String? // ENTRY, MID_LEVEL, SENIOR, DIRECTOR
  workMode        String? // REMOTE, HYBRID, ONSITE
  companySize     String? // STARTUP, MID_SIZE, ENTERPRISE
  viewCount       Int           @default(0)
  recruiterId     String?
  recruiter       Recruiter?    @relation(fields: [recruiterId], references: [id])
  applications    Application[]
  matches         Match[]
  savedJobs       SavedJob[]
  feedbacks       JobFeedback[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Match {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  score     Int
  reasoning String?
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id])
  status      String   @default("PENDING") // PENDING, SHORTLISTED, REJECTED
  coverLetter String?
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  statusHistory ApplicationStatusHistory[]

  @@unique([userId, jobId])
}

model ApplicationStatusHistory {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        String
  note          String?
  changedAt     DateTime    @default(now())
}

model Recruiter {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  companyName String?
  companyLogo String?
  description String? 
  culture     String? // Details about company culture
  website     String?
  industry    String?
  size        String? // 1-10, 11-50, 51-200, etc.
  jobs        Job[]
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String // IMPROVEMENT, MATCH, CLICK
  data      String // JSON string
  createdAt DateTime @default(now())
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

model JobFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  rating    Int      // e.g. 1-5
  comment   String?
  issueType String?  // e.g. SPAM, INACCURATE, GREAT_MATCH
  createdAt DateTime @default(now())
}

model JobPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  keywords         String?  // JSON array
  categories       String?  // JSON array
  workModes        String?  // JSON array
  experienceLevels String?  // JSON array
  emailAlerts      Boolean  @default(false)
  inAppAlerts      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
